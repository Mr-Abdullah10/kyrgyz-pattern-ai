# ── Kyrgyz Pattern AI — Environment Variables ──
# Copy this file to .env and fill in the values you have.
# The app works WITHOUT any keys (uses Pollinations.ai free API).
# Adding keys enables higher-quality generation backends.

# Option 1: Stability AI (best quality, paid ~$0.002/image)
# Get key at: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Option 2: HuggingFace Inference API (good quality, free tier)
# Get token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Option 3: Together AI (good quality, free tier - 1000 req/day)
# Get key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Optional: override the HuggingFace model (default: SDXL)
# HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
